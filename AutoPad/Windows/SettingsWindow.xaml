<Window x:Class="AutoPad.Windows.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AutoPad - 설정"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E1E"
        Width="480"
        Height="520"
        MinWidth="420"
        MinHeight="400"
        ResizeMode="NoResize"
        ShowInTaskbar="True"
        Closing="Window_Closing">
    
    <Window.Resources>
        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>
        
        <Style x:Key="DarkComboBoxItem" TargetType="ComboBoxItem">
            <Setter Property="Background" Value="#2D2D30"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border Background="{TemplateBinding Background}" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter Property="Background" Value="#0078D4"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#3F3F46"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <Style x:Key="DarkComboBox" TargetType="ComboBox">
            <Setter Property="Background" Value="#2D2D30"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="BorderBrush" Value="#3F3F46"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="ItemContainerStyle" Value="{StaticResource DarkComboBoxItem}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleBtn"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          Focusable="False"
                                          ClickMode="Press">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="Border"
                                                Background="{Binding Background, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                BorderBrush="{Binding BorderBrush, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                BorderThickness="1"
                                                CornerRadius="4"
                                                Cursor="Hand">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="30"/>
                                                </Grid.ColumnDefinitions>
                                                <ContentPresenter Grid.Column="0"
                                                                  Margin="10,8"
                                                                  Content="{Binding SelectionBoxItem, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                                  ContentTemplate="{Binding SelectionBoxItemTemplate, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                                  TextElement.Foreground="#E0E0E0"
                                                                  VerticalAlignment="Center"
                                                                  HorizontalAlignment="Left"/>
                                                <Path Grid.Column="1"
                                                      Data="M0,0 L4,4 L8,0" 
                                                      Stroke="#AAAAAA" 
                                                      StrokeThickness="1.5"
                                                      HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Border" Property="BorderBrush" Value="#0078D4"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <Popup IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Placement="Bottom"
                                   AllowsTransparency="True"
                                   PopupAnimation="Slide"
                                   Focusable="False">
                                <Border Background="#2D2D30"
                                        BorderBrush="#3F3F46"
                                        BorderThickness="1"
                                        CornerRadius="4"
                                        Margin="0,2,0,0"
                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}">
                                    <ScrollViewer MaxHeight="200">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <Style x:Key="DarkCheckBox" TargetType="CheckBox">
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,8,0,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal">
                            <Border x:Name="CheckBorder"
                                    Width="18" Height="18"
                                    Background="#2D2D30"
                                    BorderBrush="#3F3F46"
                                    BorderThickness="1"
                                    CornerRadius="3"
                                    VerticalAlignment="Center">
                                <TextBlock x:Name="CheckMark"
                                           Text="&#xE73E;"
                                           FontFamily="Segoe Fluent Icons"
                                           Foreground="White"
                                           FontSize="12"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Visibility="Collapsed"/>
                            </Border>
                            <ContentPresenter Margin="8,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="CheckBorder" Property="Background" Value="#0078D4"/>
                                <Setter TargetName="CheckBorder" Property="BorderBrush" Value="#0078D4"/>
                                <Setter TargetName="CheckMark" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="CheckBorder" Property="BorderBrush" Value="#0078D4"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <Style x:Key="SaveButton" TargetType="Button">
            <Setter Property="Background" Value="#0078D4"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="24,12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#106EBE"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 탭 버튼 스타일 -->
        <Style x:Key="TabBtn" TargetType="RadioButton">
            <Setter Property="Foreground" Value="#888888"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,0,4,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Bd" Background="Transparent" CornerRadius="4" Padding="14,8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#0078D4"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="IsChecked" Value="False"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Bd" Property="Background" Value="#3F3F46"/>
                                <Setter Property="Foreground" Value="#E0E0E0"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- 헤더 -->
        <Grid Grid.Row="0" Margin="0,0,0,16">
            <TextBlock x:Name="SettingsHeaderText"
                       Text="설정"
                       Foreground="White"
                       FontSize="20"
                       FontWeight="SemiBold"
                       VerticalAlignment="Center"/>
            <TextBlock x:Name="VersionText"
                       Foreground="#666666"
                       FontSize="11"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Right"/>
        </Grid>

        <!-- 탭 바 -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,16">
            <RadioButton x:Name="TabGeneral" Content="General" Style="{StaticResource TabBtn}" IsChecked="True" Checked="Tab_Checked"/>
            <RadioButton x:Name="TabNotification" Content="Notification" Style="{StaticResource TabBtn}" Checked="Tab_Checked"/>
            <RadioButton x:Name="TabHistory" Content="History" Style="{StaticResource TabBtn}" Checked="Tab_Checked"/>
            <RadioButton x:Name="TabMacro" Content="Macro" Style="{StaticResource TabBtn}" Checked="Tab_Checked"/>
        </StackPanel>

        <!-- 탭 콘텐츠 -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Style="{StaticResource DarkScrollViewer}">
        <Grid>
            <!-- 일반 탭 -->
            <StackPanel x:Name="PanelGeneral">
                <TextBlock x:Name="LanguageLabelText" Text="언어" Style="{StaticResource LabelStyle}"/>
                <ComboBox x:Name="LanguageComboBox" Style="{StaticResource DarkComboBox}">
                    <ComboBoxItem Content="English" Tag="en"/>
                    <ComboBoxItem Content="한국어" Tag="ko"/>
                </ComboBox>

                <CheckBox x:Name="MonitoringCheckBox" 
                          Content="클립보드 모니터링 활성화" 
                          Style="{StaticResource DarkCheckBox}"
                          Margin="0,20,0,0"
                          Checked="MonitoringCheckBox_Changed"
                          Unchecked="MonitoringCheckBox_Changed"/>

                <CheckBox x:Name="ImageMonitoringCheckBox" 
                          Content="이미지 복사 모니터링 활성화" 
                          Style="{StaticResource DarkCheckBox}"
                          Margin="24,8,0,0"/>

                <CheckBox x:Name="FileMonitoringCheckBox" 
                          Content="파일 복사 모니터링 활성화" 
                          Style="{StaticResource DarkCheckBox}"
                          Margin="24,8,0,0"/>

                <StackPanel Orientation="Horizontal" Margin="24,8,0,0">
                    <TextBlock x:Name="FileSizeLimitLabel" Text="파일 크기 제한:" Foreground="#AAAAAA" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <ComboBox x:Name="FileSizeComboBox" Style="{StaticResource DarkComboBox}" Width="100">
                        <ComboBoxItem Content="1 MB" Tag="1"/>
                        <ComboBoxItem Content="5 MB" Tag="5"/>
                        <ComboBoxItem Content="10 MB" Tag="10"/>
                        <ComboBoxItem Content="50 MB" Tag="50"/>
                        <ComboBoxItem Content="100 MB" Tag="100"/>
                    </ComboBox>
                </StackPanel>

                <CheckBox x:Name="StartWithWindowsCheckBox" 
                          Content="Windows 시작 시 자동 실행" 
                          Style="{StaticResource DarkCheckBox}"
                          Margin="0,20,0,0"/>

                <CheckBox x:Name="StartMinimizedCheckBox" 
                          Content="시작 시 최소화 (트레이)" 
                          Style="{StaticResource DarkCheckBox}"/>

                <!-- 맞춤법 검사 -->
                <StackPanel Orientation="Horizontal" Margin="0,20,0,0">
                    <CheckBox x:Name="SpellCheckCheckBox"
                              Content="맞춤법 검사"
                              Style="{StaticResource DarkCheckBox}"/>
                    <Button x:Name="SpellCheckHelpButton"
                            Content="&#xE897;"
                            FontFamily="Segoe Fluent Icons"
                            FontSize="14"
                            Foreground="#888888"
                            Background="Transparent"
                            BorderThickness="0"
                            Cursor="Hand"
                            VerticalAlignment="Center"
                            Margin="6,0,0,0"
                            ToolTipService.InitialShowDelay="0"
                            ToolTipService.ShowDuration="30000">
                        <Button.ToolTip>
                            <ToolTip MaxWidth="350" Background="#333337" Foreground="#E0E0E0" BorderBrush="#555555">
                                <TextBlock x:Name="SpellCheckTooltipText"
                                           Text="Windows 기본 맞춤법 검사를 사용합니다."
                                           TextWrapping="Wrap"/>
                            </ToolTip>
                        </Button.ToolTip>
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="Transparent">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Foreground" Value="#CCCCCC"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </StackPanel>

            <!-- 알림 탭 -->
            <StackPanel x:Name="PanelNotification" Visibility="Collapsed">
                <TextBlock x:Name="PositionLabelText" Text="토스트 알림 위치" Style="{StaticResource LabelStyle}"/>
                <ComboBox x:Name="PositionComboBox" Style="{StaticResource DarkComboBox}" SelectionChanged="PositionComboBox_SelectionChanged">
                    <ComboBoxItem x:Name="PosBottom" Content="하단 중앙" Tag="Bottom"/>
                    <ComboBoxItem x:Name="PosTop" Content="상단 중앙" Tag="Top"/>
                    <ComboBoxItem x:Name="PosBottomLeft" Content="하단 왼쪽" Tag="BottomLeft"/>
                    <ComboBoxItem x:Name="PosBottomRight" Content="하단 오른쪽" Tag="BottomRight"/>
                    <ComboBoxItem x:Name="PosTopLeft" Content="상단 왼쪽" Tag="TopLeft"/>
                    <ComboBoxItem x:Name="PosTopRight" Content="상단 오른쪽" Tag="TopRight"/>
                </ComboBox>

                <TextBlock x:Name="DurationLabelText" Text="알림 표시 시간 (초)" Style="{StaticResource LabelStyle}" Margin="0,20,0,8"/>
                <ComboBox x:Name="DurationComboBox" Style="{StaticResource DarkComboBox}">
                    <ComboBoxItem x:Name="Dur3" Content="3초" Tag="3"/>
                    <ComboBoxItem x:Name="Dur5" Content="5초" Tag="5"/>
                    <ComboBoxItem x:Name="Dur10" Content="10초" Tag="10"/>
                    <ComboBoxItem x:Name="Dur15" Content="15초" Tag="15"/>
                </ComboBox>

                <CheckBox x:Name="CompactModeCheckBox" 
                          Content="컴팩트 알림 (버튼만 표시)" 
                          Style="{StaticResource DarkCheckBox}"
                          Margin="0,20,0,0"
                          Checked="NotificationSettingChanged"
                          Unchecked="NotificationSettingChanged"/>

                <!-- 투명도 슬라이더 -->
                <TextBlock x:Name="OpacityLabelText" Text="알림 투명도" Style="{StaticResource LabelStyle}" Margin="0,20,0,0"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="50"/>
                    </Grid.ColumnDefinitions>
                    <Slider x:Name="OpacitySlider" Grid.Column="0"
                            Minimum="10" Maximum="100" Value="100"
                            TickFrequency="10" IsSnapToTickEnabled="True"
                            VerticalAlignment="Center"
                            ValueChanged="OpacitySlider_ValueChanged"/>
                    <TextBlock x:Name="OpacityValueText" Grid.Column="1"
                               Text="100%"
                               Foreground="#AAAAAA"
                               FontSize="12"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Center"/>
                </Grid>
            </StackPanel>

            <!-- 히스토리 탭 -->
            <StackPanel x:Name="PanelHistory" Visibility="Collapsed">
                <CheckBox x:Name="HistoryCheckBox" 
                          Content="클립보드 히스토리 활성화" 
                          Style="{StaticResource DarkCheckBox}"
                          Margin="0,0,0,0"/>

                <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                    <TextBlock x:Name="HistorySizeLabel" Text="히스토리 개수:" Foreground="#AAAAAA" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <ComboBox x:Name="HistorySizeComboBox" Style="{StaticResource DarkComboBox}" Width="100">
                        <ComboBoxItem Content="20" Tag="20"/>
                        <ComboBoxItem Content="50" Tag="50"/>
                        <ComboBoxItem Content="100" Tag="100"/>
                        <ComboBoxItem Content="200" Tag="200"/>
                    </ComboBox>
                </StackPanel>
            </StackPanel>

        </Grid>
        </ScrollViewer>

        <!-- 매크로 탭 (ScrollViewer 외부 — 목록 자체 스크롤) -->
        <Grid x:Name="PanelMacro" Grid.Row="2" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock x:Name="MacroDescLabel" 
                           Text="JavaScript macros for text transformation"
                           Foreground="#AAAAAA" FontSize="12" Margin="0,0,0,12"/>

                <!-- 매크로 목록 -->
                <Border Grid.Row="1" Background="#252526" CornerRadius="4" BorderBrush="#3F3F46" BorderThickness="1">
                    <ListBox x:Name="MacroListBox"
                             Background="Transparent"
                             BorderThickness="0"
                             Foreground="#E0E0E0"
                             FontSize="13"
                             SelectionChanged="MacroListBox_SelectionChanged"
                             KeyDown="MacroListBox_KeyDown">
                        <ListBox.Resources>
                            <Style TargetType="ScrollBar" BasedOn="{StaticResource DarkScrollBar}"/>
                        </ListBox.Resources>
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Foreground" Value="#E0E0E0"/>
                                <Setter Property="Padding" Value="10,8"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#3E3E42"/>
                                                </Trigger>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter Property="Background" Value="#0078D4"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>
                </Border>

                <!-- 매크로 관리 버튼 -->
                <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,8,0,0">
                    <Button x:Name="MacroAddButton" Content="+"
                            Click="MacroAddButton_Click"
                            Background="#3C3C3C" Foreground="#E0E0E0" BorderThickness="0"
                            Width="32" Height="32" Cursor="Hand" FontSize="16" FontWeight="Bold">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="4">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#505050"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button x:Name="MacroEditButton" Content="&#xE70F;"
                            FontFamily="Segoe Fluent Icons"
                            Click="MacroEditButton_Click"
                            Background="#3C3C3C" Foreground="#E0E0E0" BorderThickness="0"
                            Width="32" Height="32" Cursor="Hand" FontSize="14" Margin="4,0,0,0"
                            IsEnabled="False">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="4" Opacity="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=IsEnabled, Converter={x:Null}}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#505050"/>
                                    </Trigger>
                                    <Trigger Property="IsEnabled" Value="False">
                                        <Setter Property="Opacity" Value="0.4"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button x:Name="MacroDeleteButton" Content="&#xE74D;"
                            FontFamily="Segoe Fluent Icons"
                            Click="MacroDeleteButton_Click"
                            Background="#3C3C3C" Foreground="#E0E0E0" BorderThickness="0"
                            Width="32" Height="32" Cursor="Hand" FontSize="14" Margin="4,0,0,0"
                            IsEnabled="False">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="4">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#505050"/>
                                    </Trigger>
                                    <Trigger Property="IsEnabled" Value="False">
                                        <Setter Property="Opacity" Value="0.4"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <Rectangle Width="1" Fill="#3F3F46" Margin="8,4"/>

                    <!-- 순서 변경 버튼 -->
                    <Button x:Name="MacroMoveUpButton" Content="&#xE74A;"
                            FontFamily="Segoe Fluent Icons"
                            Click="MacroMoveUpButton_Click"
                            Background="#3C3C3C" Foreground="#E0E0E0" BorderThickness="0"
                            Width="32" Height="32" Cursor="Hand" FontSize="14"
                            IsEnabled="False">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="4">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#505050"/>
                                    </Trigger>
                                    <Trigger Property="IsEnabled" Value="False">
                                        <Setter Property="Opacity" Value="0.4"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button x:Name="MacroMoveDownButton" Content="&#xE74B;"
                            FontFamily="Segoe Fluent Icons"
                            Click="MacroMoveDownButton_Click"
                            Background="#3C3C3C" Foreground="#E0E0E0" BorderThickness="0"
                            Width="32" Height="32" Cursor="Hand" FontSize="14" Margin="4,0,0,0"
                            IsEnabled="False">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="4">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#505050"/>
                                    </Trigger>
                                    <Trigger Property="IsEnabled" Value="False">
                                        <Setter Property="Opacity" Value="0.4"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- 구분선 -->
                    <Rectangle Width="1" Fill="#3F3F46" Margin="8,4"/>

                    <!-- 프리셋 버튼 -->
                    <Button x:Name="MacroPresetButton"
                            Click="MacroPresetButton_Click"
                            Background="#3C3C3C" Foreground="#E0E0E0" BorderThickness="0"
                            Height="32" Cursor="Hand" FontSize="12" Padding="10,0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="10,0">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#505050"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="&#xE710;" FontFamily="Segoe Fluent Icons" FontSize="12" Foreground="#E0E0E0" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock x:Name="MacroPresetButtonText" Text="Presets" Foreground="#E0E0E0" VerticalAlignment="Center" FontSize="12"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>

        <!-- 저장 버튼 -->
        <Button x:Name="SettingsSaveButton" Grid.Row="3"
