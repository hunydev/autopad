<Window x:Class="AutoPad.Windows.EditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AutoPad - 편집"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E1E"
        Width="900"
        Height="650"
        MinWidth="700"
        MinHeight="500"
        ShowInTaskbar="True">
    
    <Window.Resources>
        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Background" Value="#0078D4"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20,12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#106EBE"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#005A9E"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="#3C3C3C"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20,12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#505050"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#606060"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <Style x:Key="ToolButton" TargetType="Button">
            <Setter Property="Background" Value="#3C3C3C"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="36"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" 
                                Background="{TemplateBinding Background}" 
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#505050"/>
                            </Trigger>
                            <Trigger Property="Tag" Value="Selected">
                                <Setter TargetName="Bd" Property="Background" Value="#0078D4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <Style x:Key="ColorButton" TargetType="Button">
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" 
                                Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#0078D4"/>
                            </Trigger>
                            <Trigger Property="Tag" Value="Selected">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- 다크 테마 인코딩 콤보박스 스타일 -->
        <Style x:Key="DarkEncodingComboBoxItem" TargetType="ComboBoxItem">
            <Setter Property="Background" Value="#2D2D30"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border Background="{TemplateBinding Background}" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#3E3E42"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#0078D4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <Style x:Key="DarkEncodingComboBox" TargetType="ComboBox">
            <Setter Property="Background" Value="#2D2D30"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="BorderBrush" Value="#3F3F46"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="ItemContainerStyle" Value="{StaticResource DarkEncodingComboBoxItem}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton"
                                          Background="{TemplateBinding Background}"
                                          BorderBrush="{TemplateBinding BorderBrush}"
                                          BorderThickness="{TemplateBinding BorderThickness}"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          Focusable="false"
                                          ClickMode="Press">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="4">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition/>
                                                    <ColumnDefinition Width="20"/>
                                                </Grid.ColumnDefinitions>
                                                <ContentPresenter Grid.Column="0"/>
                                                <Path Grid.Column="1" 
                                                      Data="M 0 0 L 4 4 L 8 0 Z" 
                                                      Fill="#E0E0E0" 
                                                      HorizontalAlignment="Center" 
                                                      VerticalAlignment="Center"/>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#3E3E42"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter x:Name="ContentSite"
                                              IsHitTestVisible="False"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              Margin="8,6,24,6"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Left"/>
                            <Popup x:Name="Popup"
                                   Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Slide">
                                <Border x:Name="DropDownBorder"
                                        Background="#2D2D30"
                                        BorderBrush="#3F3F46"
                                        BorderThickness="1"
                                        MinWidth="{TemplateBinding ActualWidth}"
                                        MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <ScrollViewer>
                                        <StackPanel IsItemsHost="True"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- 다크 테마 스크롤바 스타일 -->
        <Style x:Key="DarkScrollBar" TargetType="ScrollBar">
            <Setter Property="Background" Value="#2D2D30"/>
            <Setter Property="Width" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Border Background="#2D2D30" CornerRadius="4">
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.Thumb>
                                    <Thumb Style="{x:Null}">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border x:Name="ThumbBorder" Background="#5A5A5A" CornerRadius="4" Margin="2"/>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="ThumbBorder" Property="Background" Value="#787878"/>
                                                    </Trigger>
                                                    <Trigger Property="IsDragging" Value="True">
                                                        <Setter TargetName="ThumbBorder" Property="Background" Value="#9A9A9A"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Horizontal">
                    <Setter Property="Width" Value="Auto"/>
                    <Setter Property="Height" Value="12"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ScrollBar">
                                <Border Background="#2D2D30" CornerRadius="4">
                                    <Track x:Name="PART_Track" IsDirectionReversed="False">
                                        <Track.Thumb>
                                            <Thumb Style="{x:Null}">
                                                <Thumb.Template>
                                                    <ControlTemplate TargetType="Thumb">
                                                        <Border x:Name="ThumbBorder" Background="#5A5A5A" CornerRadius="4" Margin="2"/>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="ThumbBorder" Property="Background" Value="#787878"/>
                                                            </Trigger>
                                                            <Trigger Property="IsDragging" Value="True">
                                                                <Setter TargetName="ThumbBorder" Property="Background" Value="#9A9A9A"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Thumb.Template>
                                            </Thumb>
                                        </Track.Thumb>
                                    </Track>
                                </Border>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DarkScrollViewer" TargetType="ScrollViewer">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollViewer">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <ScrollContentPresenter Grid.Column="0" Grid.Row="0"/>
                            <ScrollBar x:Name="PART_VerticalScrollBar"
                                       Grid.Column="1" Grid.Row="0"
                                       Style="{StaticResource DarkScrollBar}"
                                       Value="{TemplateBinding VerticalOffset}"
                                       Maximum="{TemplateBinding ScrollableHeight}"
                                       ViewportSize="{TemplateBinding ViewportHeight}"
                                       Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"/>
                            <ScrollBar x:Name="PART_HorizontalScrollBar"
                                       Grid.Column="0" Grid.Row="1"
                                       Orientation="Horizontal"
                                       Style="{StaticResource DarkScrollBar}"
                                       Value="{TemplateBinding HorizontalOffset}"
                                       Maximum="{TemplateBinding ScrollableWidth}"
                                       ViewportSize="{TemplateBinding ViewportWidth}"
                                       Visibility="{TemplateBinding ComputedHorizontalScrollBarVisibility}"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- 헤더 -->
        <TextBlock Grid.Row="0"
                   x:Name="SubtitleText"
                   Text="내용을 편집하고 복사하세요"
                   Foreground="#AAAAAA"
                   FontSize="12"
                   Margin="0,0,0,12"/>

        <!-- 인코딩 선택 툴바 (텍스트 파일 모드용) -->
        <Border x:Name="EncodingToolbar"
                Grid.Row="1"
                Background="#252526"
                CornerRadius="4"
                Padding="8"
                Margin="0,0,0,12"
                Visibility="Collapsed">
            <StackPanel Orientation="Horizontal">
                <TextBlock x:Name="EncodingLabel" Text="인코딩:" Foreground="#AAAAAA" VerticalAlignment="Center" Margin="4,0,8,0"/>
                <ComboBox x:Name="EncodingComboBox" 
                          Width="120"
                          Style="{StaticResource DarkEncodingComboBox}"
                          SelectionChanged="EncodingComboBox_SelectionChanged">
                    <ComboBoxItem Content="UTF-8" Tag="UTF8" IsSelected="True"/>
                    <ComboBoxItem Content="EUC-KR" Tag="EUCKR"/>
                </ComboBox>
            </StackPanel>
        </Border>
        
        <!-- 이미지 툴바 -->
        <Border x:Name="ImageToolbar"
                Grid.Row="2"
                Background="#252526"
                CornerRadius="4"
                Padding="8"
                Margin="0,0,0,12"
                Visibility="Collapsed">
            <StackPanel Orientation="Horizontal">
                <Button x:Name="PenToolButton" 
                        Style="{StaticResource ToolButton}" 
                        ToolTip="펜"
                        Click="PenToolButton_Click"
                        Tag="Selected">
                    <TextBlock Text="&#xED63;" FontFamily="Segoe Fluent Icons" FontSize="16" Foreground="#E0E0E0"/>
                </Button>
                
                <Button x:Name="EraserToolButton" 
                        Style="{StaticResource ToolButton}" 
                        ToolTip="지우개"
                        Click="EraserToolButton_Click">
                    <TextBlock Text="&#xE75C;" FontFamily="Segoe Fluent Icons" FontSize="16" Foreground="#E0E0E0"/>
                </Button>
                
                <Button x:Name="SelectToolButton"
                        Style="{StaticResource ToolButton}"
                        ToolTip="영역 선택"
                        Click="SelectToolButton_Click">
                    <TextBlock Text="&#xEF20;" FontFamily="Segoe Fluent Icons" FontSize="16" Foreground="#E0E0E0"/>
                </Button>
                
                <Rectangle Width="1" Fill="#3F3F46" Margin="8,4"/>
                
                <!-- 펜 도구 옵션 패널 -->
                <StackPanel x:Name="PenOptionsPanel" Orientation="Horizontal">
                    <Button x:Name="ColorBlack" Style="{StaticResource ColorButton}" Background="#000000" Click="ColorButton_Click" Tag="Selected"/>
                    <Button x:Name="ColorRed" Style="{StaticResource ColorButton}" Background="#FF4444" Click="ColorButton_Click"/>
                    <Button x:Name="ColorOrange" Style="{StaticResource ColorButton}" Background="#FF8C00" Click="ColorButton_Click"/>
                    <Button x:Name="ColorYellow" Style="{StaticResource ColorButton}" Background="#FFD700" Click="ColorButton_Click"/>
                    <Button x:Name="ColorGreen" Style="{StaticResource ColorButton}" Background="#44DD44" Click="ColorButton_Click"/>
                    <Button x:Name="ColorBlue" Style="{StaticResource ColorButton}" Background="#4488FF" Click="ColorButton_Click"/>
                    <Button x:Name="ColorPurple" Style="{StaticResource ColorButton}" Background="#AA44FF" Click="ColorButton_Click"/>
                    <Button x:Name="ColorWhite" Style="{StaticResource ColorButton}" Background="#FFFFFF" Click="ColorButton_Click"/>
                    
                    <Rectangle Width="1" Fill="#3F3F46" Margin="8,4"/>
                    
                    <TextBlock x:Name="ThicknessLabel" Text="굵기:" Foreground="#AAAAAA" VerticalAlignment="Center" Margin="4,0"/>
                    <Slider x:Name="BrushSizeSlider" 
                            Width="80" 
                            Minimum="2" 
                            Maximum="20" 
                            Value="4"
                            VerticalAlignment="Center"
                            Margin="4,0"
                            ValueChanged="BrushSizeSlider_ValueChanged"/>
                </StackPanel>
                
                <!-- 지우개 도구 옵션 패널 -->
                <StackPanel x:Name="EraserOptionsPanel" Orientation="Horizontal" Visibility="Collapsed">
                    <Button x:Name="EraseByStrokeButton"
                            Style="{StaticResource ToolButton}"
                            ToolTip="획 단위 지우기 - 펜 획 전체를 지움"
                            Click="EraseByStrokeButton_Click"
                            Width="Auto"
                            Height="36"
                            Padding="8,0"
                            Tag="Selected">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE75C;" FontFamily="Segoe Fluent Icons" FontSize="14" Foreground="#E0E0E0" Margin="0,0,4,0"/>
                            <TextBlock x:Name="EraseByStrokeText" Text="획 지우기" Foreground="#E0E0E0" VerticalAlignment="Center" FontSize="12"/>
                        </StackPanel>
                    </Button>
                    
                    <Button x:Name="EraseByPointButton"
                            Style="{StaticResource ToolButton}"
                            ToolTip="부분 지우기 - 지우개가 닿는 부분만 지움"
                            Click="EraseByPointButton_Click"
                            Width="Auto"
                            Height="36"
                            Padding="8,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xED63;" FontFamily="Segoe Fluent Icons" FontSize="14" Foreground="#E0E0E0" Margin="0,0,4,0"/>
                            <TextBlock x:Name="EraseByPointText" Text="부분 지우기" Foreground="#E0E0E0" VerticalAlignment="Center" FontSize="12"/>
                        </StackPanel>
                    </Button>
                    
                    <Rectangle Width="1" Fill="#3F3F46" Margin="8,4"/>
                    
                    <TextBlock x:Name="EraserSizeLabel" Text="크기:" Foreground="#AAAAAA" VerticalAlignment="Center" Margin="4,0"/>
                    <Slider x:Name="EraserSizeSlider"
                            Width="80"
                            Minimum="5"
                            Maximum="50"
                            Value="20"
                            VerticalAlignment="Center"
                            Margin="4,0"
                            ValueChanged="EraserSizeSlider_ValueChanged"/>
                </StackPanel>
                
                <!-- 영역 선택 도구 옵션 패널 -->
                <StackPanel x:Name="SelectOptionsPanel" Orientation="Horizontal" Visibility="Collapsed">
                    <Button x:Name="MosaicSelectionButton"
                            Style="{StaticResource ToolButton}"
                            ToolTip="선택 영역 모자이크"
                            Click="MosaicSelectionButton_Click"
                            Width="80"
                            Height="36"
                            Padding="8,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xF0E2;" FontFamily="Segoe Fluent Icons" FontSize="14" Foreground="#E0E0E0" Margin="0,0,4,0"/>
                            <TextBlock x:Name="MosaicText" Text="모자이크" Foreground="#E0E0E0" VerticalAlignment="Center" FontSize="12"/>
                        </StackPanel>
                    </Button>
                    
                    <Button x:Name="FillSelectionButton"
                            Style="{StaticResource ToolButton}"
                            ToolTip="선택 영역 단색 채우기 (색상 선택)"
                            Click="FillSelectionButton_Click"
                            Width="68"
                            Height="36"
                            Padding="8,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE771;" FontFamily="Segoe Fluent Icons" FontSize="14" Foreground="#E0E0E0" Margin="0,0,4,0"/>
                            <TextBlock x:Name="FillText" Text="채우기" Foreground="#E0E0E0" VerticalAlignment="Center" FontSize="12"/>
                        </StackPanel>
                    </Button>
                    
                    <Button x:Name="EraseSelectionButton"
                            Style="{StaticResource ToolButton}"
                            ToolTip="선택 영역 없애기 (투명)"
                            Click="EraseSelectionButton_Click"
                            Width="68"
                            Height="36"
                            Padding="8,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE711;" FontFamily="Segoe Fluent Icons" FontSize="14" Foreground="#E0E0E0" Margin="0,0,4,0"/>
                            <TextBlock x:Name="EraseText" Text="없애기" Foreground="#E0E0E0" VerticalAlignment="Center" FontSize="12"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
                
                <Rectangle Width="1" Fill="#3F3F46" Margin="8,4"/>
                
                <Button x:Name="UndoButton" 
                        Style="{StaticResource ToolButton}" 
                        ToolTip="실행취소 (Ctrl+Z)"
                        Click="UndoButton_Click">
                    <TextBlock Text="&#xE7A7;" FontFamily="Segoe Fluent Icons" FontSize="14" Foreground="#E0E0E0"/>
                </Button>
                
                <Button x:Name="ClearButton" 
                        Style="{StaticResource ToolButton}" 
                        ToolTip="그린 내용 모두 지우기"
                        Click="ClearButton_Click">
                    <TextBlock Text="&#xE74D;" FontFamily="Segoe Fluent Icons" FontSize="14" Foreground="#E0E0E0"/>
                </Button>
                
                <Rectangle Width="1" Fill="#3F3F46" Margin="8,4"/>
                
                <Button x:Name="FitToggleButton"
                        Style="{StaticResource ToolButton}"
                        ToolTip="창에 맞추기 / 원본 크기"
                        Click="FitToggleButton_Click"
                        Width="76"
                        Padding="8,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock x:Name="FitToggleIcon" Text="&#xE9A6;" FontFamily="Segoe Fluent Icons" FontSize="14" Foreground="#E0E0E0" Margin="0,0,4,0"/>
                        <TextBlock x:Name="FitToggleText" Text="맞추기" Foreground="#E0E0E0" VerticalAlignment="Center" FontSize="12"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Border>
        
        <!-- 텍스트 편집 영역 -->
        <TextBox x:Name="ContentTextBox"
                 Grid.Row="3"
                 AcceptsReturn="True"
                 AcceptsTab="True"
                 TextWrapping="Wrap"
                 VerticalScrollBarVisibility="Auto"
                 HorizontalScrollBarVisibility="Auto"
                 Background="#2D2D30"
                 Foreground="#E0E0E0"
                 BorderBrush="#3F3F46"
                 BorderThickness="1"
                 Padding="12"
                 FontFamily="Consolas"
                 FontSize="14"
                 CaretBrush="White"
                 SelectionBrush="#0078D4">
            <TextBox.Resources>
                <Style TargetType="ScrollBar" BasedOn="{StaticResource DarkScrollBar}"/>
            </TextBox.Resources>
        </TextBox>
        
        <!-- 이미지 편집 영역 -->
        <Border x:Name="ImageContainer"
                Grid.Row="3"
                Background="#2D2D30"
                BorderBrush="#3F3F46"
                BorderThickness="1"
                Visibility="Collapsed">
            <ScrollViewer x:Name="ImageScrollViewer"
                          HorizontalScrollBarVisibility="Auto" 
                          VerticalScrollBarVisibility="Auto"
                          Style="{StaticResource DarkScrollViewer}">
                <Canvas x:Name="CanvasContainer" 
                        ClipToBounds="True"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Top">
                    <Image x:Name="ContentImage"
                           Stretch="None"
                           Canvas.Left="0"
                           Canvas.Top="0"/>
                    <InkCanvas x:Name="DrawingCanvas"
                               Background="Transparent"
                               EditingMode="Ink"
                               Canvas.Left="0"
                               Canvas.Top="0"/>
                    <!-- 영역 선택 사각형 -->
                    <Border x:Name="SelectionRectangle"
                            BorderBrush="#0078D4"
                            BorderThickness="1.5"
                            Background="#200078D4"
                            Visibility="Collapsed"
                            IsHitTestVisible="False">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="0" ShadowDepth="0"/>
                        </Border.Effect>
                    </Border>
                </Canvas>
            </ScrollViewer>
        </Border>
        
        <!-- 버튼 영역 -->
        <StackPanel Grid.Row="4"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,16,0,0">
            
            <TextBlock x:Name="StatusText"
                       Foreground="#4EC9B0"
                       FontSize="12"
                       VerticalAlignment="Center"
                       Margin="0,0,16,0"/>
            
            <Button x:Name="SaveButton"
                    Content="저장"
                    Style="{StaticResource SecondaryButton}"
                    Click="SaveButton_Click"
                    Visibility="Collapsed"
                    Margin="0,0,8,0"/>
            
            <Button x:Name="CopySelectedButton"
                    Content="선택 영역 복사"
                    Style="{StaticResource SecondaryButton}"
                    Click="CopySelectedButton_Click"
                    Margin="0,0,8,0"/>
            
            <Button x:Name="CopyAllButton"
                    Content="복사 후 닫기"
                    Style="{StaticResource ActionButton}"
                    Click="CopyAllButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
