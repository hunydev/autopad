<Window x:Class="AutoPad.Windows.EditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AutoPad - 편집"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E1E"
        Width="900"
        Height="650"
        MinWidth="700"
        MinHeight="500"
        ShowInTaskbar="True">
    
    <Window.Resources>
        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Background" Value="#0078D4"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20,12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#106EBE"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#005A9E"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="#3C3C3C"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20,12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#505050"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#606060"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <Style x:Key="ToolButton" TargetType="Button">
            <Setter Property="Background" Value="#3C3C3C"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="36"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" 
                                Background="{TemplateBinding Background}" 
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#505050"/>
                            </Trigger>
                            <Trigger Property="Tag" Value="Selected">
                                <Setter TargetName="Bd" Property="Background" Value="#0078D4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <Style x:Key="ColorButton" TargetType="Button">
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" 
                                Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#0078D4"/>
                            </Trigger>
                            <Trigger Property="Tag" Value="Selected">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- 다크 테마 인코딩 콤보박스 스타일 -->
        <Style x:Key="DarkEncodingComboBoxItem" TargetType="ComboBoxItem">
            <Setter Property="Background" Value="#2D2D30"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border Background="{TemplateBinding Background}" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#3E3E42"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#0078D4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <Style x:Key="DarkEncodingComboBox" TargetType="ComboBox">
            <Setter Property="Background" Value="#2D2D30"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="BorderBrush" Value="#3F3F46"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="ItemContainerStyle" Value="{StaticResource DarkEncodingComboBoxItem}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton"
                                          Background="{TemplateBinding Background}"
                                          BorderBrush="{TemplateBinding BorderBrush}"
                                          BorderThickness="{TemplateBinding BorderThickness}"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          Focusable="false"
                                          ClickMode="Press">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="4">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition/>
                                                    <ColumnDefinition Width="20"/>
                                                </Grid.ColumnDefinitions>
                                                <ContentPresenter Grid.Column="0"/>
                                                <Path Grid.Column="1" 
                                                      Data="M 0 0 L 4 4 L 8 0 Z" 
                                                      Fill="#E0E0E0" 
                                                      HorizontalAlignment="Center" 
                                                      VerticalAlignment="Center"/>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#3E3E42"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter x:Name="ContentSite"
                                              IsHitTestVisible="False"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              Margin="8,6,24,6"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Left"/>
                            <Popup x:Name="Popup"
                                   Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Slide">
                                <Border x:Name="DropDownBorder"
                                        Background="#2D2D30"
                                        BorderBrush="#3F3F46"
                                        BorderThickness="1"
                                        MinWidth="{TemplateBinding ActualWidth}"
                                        MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <ScrollViewer>
                                        <StackPanel IsItemsHost="True"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- 헤더 -->
        <TextBlock Grid.Row="0"
                   x:Name="SubtitleText"
                   Text="내용을 편집하고 복사하세요"
                   Foreground="#AAAAAA"
                   FontSize="12"
                   Margin="0,0,0,12"/>

        <!-- 인코딩 선택 툴바 (텍스트 파일 모드용) -->
        <Border x:Name="EncodingToolbar"
                Grid.Row="1"
                Background="#252526"
                CornerRadius="4"
                Padding="8"
                Margin="0,0,0,12"
                Visibility="Collapsed">
            <StackPanel Orientation="Horizontal">
                <TextBlock x:Name="EncodingLabel" Text="인코딩:" Foreground="#AAAAAA" VerticalAlignment="Center" Margin="4,0,8,0"/>
                <ComboBox x:Name="EncodingComboBox" 
                          Width="120"
                          Style="{StaticResource DarkEncodingComboBox}"
                          SelectionChanged="EncodingComboBox_SelectionChanged">
                    <ComboBoxItem Content="UTF-8" Tag="UTF8" IsSelected="True"/>
                    <ComboBoxItem Content="EUC-KR" Tag="EUCKR"/>
                </ComboBox>
            </StackPanel>
        </Border>
        
        <!-- 텍스트 도구 툴바 -->
        <Border x:Name="TextToolbar"
                Grid.Row="2"
                Background="#252526"
                CornerRadius="4"
                Padding="4"
                Margin="0,0,0,8"
                Visibility="Collapsed">
            <StackPanel Orientation="Horizontal">
                <Button x:Name="RemoveLinesButton"
                        Style="{StaticResource ToolButton}"
                        Content="라인 제거"
                        Click="RemoveLinesButton_Click"
                        Width="Auto" Height="30" Padding="12,4" FontSize="12" Foreground="#E0E0E0"/>
                
                <Button x:Name="ReplaceWhitespaceButton"
                        Style="{StaticResource ToolButton}"
                        Content="특수공백 제거"
                        Click="ReplaceWhitespaceButton_Click"
                        Width="Auto" Height="30" Padding="12,4" Margin="4,0,0,0" FontSize="12" Foreground="#E0E0E0"/>
                
                <Button x:Name="TrimButton"
                        Style="{StaticResource ToolButton}"
                        Content="TRIM"
                        Click="TrimButton_Click"
                        Width="Auto" Height="30" Padding="12,4" Margin="4,0,0,0" FontSize="12" Foreground="#E0E0E0"/>
                
                <Button x:Name="MaskNumbersButton"
                        Style="{StaticResource ToolButton}"
                        Content="숫자 마스킹"
                        Click="MaskNumbersButton_Click"
                        Width="Auto" Height="30" Padding="12,4" Margin="4,0,0,0" FontSize="12" Foreground="#E0E0E0"/>
                
                <Rectangle Width="1" Fill="#3F3F46" Margin="6,4"/>
                
                <Button x:Name="UpperCaseButton"
                        Style="{StaticResource ToolButton}"
                        Content="UPPER"
                        Click="UpperCaseButton_Click"
                        Width="Auto" Height="30" Padding="12,4" FontSize="12" Foreground="#E0E0E0"/>
                
                <Button x:Name="LowerCaseButton"
                        Style="{StaticResource ToolButton}"
                        Content="lower"
                        Click="LowerCaseButton_Click"
                        Width="Auto" Height="30" Padding="12,4" Margin="4,0,0,0" FontSize="12" Foreground="#E0E0E0"/>
            </StackPanel>
        </Border>
        
        <!-- URL 호버 버튼 -->
        <Popup x:Name="UrlPopup"
               PlacementTarget="{Binding ElementName=ContentTextBox}"
               Placement="Relative"
               StaysOpen="True"
               AllowsTransparency="True">
            <Button x:Name="UrlOpenButton"
                    Click="UrlOpenButton_Click"
                    Background="#0078D4" Foreground="White" BorderThickness="0"
                    Cursor="Hand" FontSize="11" Padding="8,4"
                    MouseLeave="UrlOpenButton_MouseLeave">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="3" Padding="{TemplateBinding Padding}">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="6" Opacity="0.3" ShadowDepth="1"/>
                            </Border.Effect>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE71B;" FontFamily="Segoe Fluent Icons" FontSize="11" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                <TextBlock x:Name="UrlOpenButtonText" Text="URL 열기" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#106EBE"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </Popup>

        <!-- 라인 제거 드롭다운 (Popup) -->
        <Popup x:Name="RemoveLinesPopup"
               PlacementTarget="{Binding ElementName=RemoveLinesButton}"
               Placement="Bottom"
               StaysOpen="False"
               AllowsTransparency="True">
            <Border Background="#333337"
                    CornerRadius="4"
                    Padding="2"
                    BorderBrush="#555555"
                    BorderThickness="1">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="8" Opacity="0.4" ShadowDepth="2"/>
                </Border.Effect>
                <StackPanel>
                    <Button x:Name="RemoveBlankLinesButton"
                            Content="공백 라인 제거"
                            Click="RemoveBlankLinesButton_Click"
                            Background="Transparent" Foreground="#E0E0E0" BorderThickness="0"
                            Padding="12,6" HorizontalContentAlignment="Left" Cursor="Hand" FontSize="12"/>
                    <Button x:Name="RemoveAllLinesButton"
                            Content="모든 라인 제거"
                            Click="RemoveAllLinesButton_Click"
                            Background="Transparent" Foreground="#E0E0E0" BorderThickness="0"
                            Padding="12,6" HorizontalContentAlignment="Left" Cursor="Hand" FontSize="12"/>
                </StackPanel>
            </Border>
        </Popup>
        
        <!-- 이미지 툴바 -->
        <Border x:Name="ImageToolbar"
                Grid.Row="2"
                Background="#252526"
                CornerRadius="4"
                Padding="8"
                Margin="0,0,0,12"
                Visibility="Collapsed">
            <StackPanel Orientation="Horizontal">
                <Button x:Name="PenToolButton" 
                        Style="{StaticResource ToolButton}" 
                        ToolTip="펜"
                        Click="PenToolButton_Click"
                        Tag="Selected">
                    <TextBlock Text="&#xED63;" FontFamily="Segoe Fluent Icons" FontSize="16" Foreground="#E0E0E0"/>
                </Button>
                
                <Button x:Name="EraserToolButton" 
                        Style="{StaticResource ToolButton}" 
                        ToolTip="지우개"
                        Click="EraserToolButton_Click">
                    <TextBlock Text="&#xE75C;" FontFamily="Segoe Fluent Icons" FontSize="16" Foreground="#E0E0E0"/>
                </Button>
                
                <Button x:Name="SelectToolButton"
                        Style="{StaticResource ToolButton}"
                        ToolTip="영역 선택"
                        Click="SelectToolButton_Click">
                    <TextBlock Text="&#xEF20;" FontFamily="Segoe Fluent Icons" FontSize="16" Foreground="#E0E0E0"/>
                </Button>
                
                <Rectangle Width="1" Fill="#3F3F46" Margin="8,4"/>
                
                <!-- 펜 도구 옵션 패널 -->
                <StackPanel x:Name="PenOptionsPanel" Orientation="Horizontal">
                    <Button x:Name="ColorBlack" Style="{StaticResource ColorButton}" Background="#000000" Click="ColorButton_Click" Tag="Selected"/>
                    <Button x:Name="ColorRed" Style="{StaticResource ColorButton}" Background="#FF4444" Click="ColorButton_Click"/>
                    <Button x:Name="ColorOrange" Style="{StaticResource ColorButton}" Background="#FF8C00" Click="ColorButton_Click"/>
                    <Button x:Name="ColorYellow" Style="{StaticResource ColorButton}" Background="#FFD700" Click="ColorButton_Click"/>
                    <Button x:Name="ColorGreen" Style="{StaticResource ColorButton}" Background="#44DD44" Click="ColorButton_Click"/>
                    <Button x:Name="ColorBlue" Style="{StaticResource ColorButton}" Background="#4488FF" Click="ColorButton_Click"/>
                    <Button x:Name="ColorPurple" Style="{StaticResource ColorButton}" Background="#AA44FF" Click="ColorButton_Click"/>
                    <Button x:Name="ColorWhite" Style="{StaticResource ColorButton}" Background="#FFFFFF" Click="ColorButton_Click"/>
                    
                    <Rectangle Width="1" Fill="#3F3F46" Margin="8,4"/>
                    
                    <TextBlock x:Name="ThicknessLabel" Text="굵기:" Foreground="#AAAAAA" VerticalAlignment="Center" Margin="4,0"/>
                    <Slider x:Name="BrushSizeSlider" 
                            Width="80" 
                            Minimum="2" 
                            Maximum="20" 
                            Value="4"
                            VerticalAlignment="Center"
                            Margin="4,0"
                            ValueChanged="BrushSizeSlider_ValueChanged"/>
                </StackPanel>
                
                <!-- 지우개 도구 옵션 패널 -->
                <StackPanel x:Name="EraserOptionsPanel" Orientation="Horizontal" Visibility="Collapsed">
                    <Button x:Name="EraseByStrokeButton"
                            Style="{StaticResource ToolButton}"
                            ToolTip="획 단위 지우기 - 펜 획 전체를 지움"
                            Click="EraseByStrokeButton_Click"
                            Width="Auto"
                            Height="36"
                            Padding="8,0"
                            Tag="Selected">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE75C;" FontFamily="Segoe Fluent Icons" FontSize="14" Foreground="#E0E0E0" Margin="0,0,4,0"/>
                            <TextBlock x:Name="EraseByStrokeText" Text="획 지우기" Foreground="#E0E0E0" VerticalAlignment="Center" FontSize="12"/>
                        </StackPanel>
                    </Button>
                    
                    <Button x:Name="EraseByPointButton"
                            Style="{StaticResource ToolButton}"
                            ToolTip="부분 지우기 - 지우개가 닿는 부분만 지움"
                            Click="EraseByPointButton_Click"
                            Width="Auto"
                            Height="36"
                            Padding="8,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xED63;" FontFamily="Segoe Fluent Icons" FontSize="14" Foreground="#E0E0E0" Margin="0,0,4,0"/>
                            <TextBlock x:Name="EraseByPointText" Text="부분 지우기" Foreground="#E0E0E0" VerticalAlignment="Center" FontSize="12"/>
                        </StackPanel>
                    </Button>
                    
                    <Rectangle Width="1" Fill="#3F3F46" Margin="8,4"/>
                    
                    <TextBlock x:Name="EraserSizeLabel" Text="크기:" Foreground="#AAAAAA" VerticalAlignment="Center" Margin="4,0"/>
                    <Slider x:Name="EraserSizeSlider"
                            Width="80"
                            Minimum="5"
                            Maximum="50"
                            Value="20"
                            VerticalAlignment="Center"
                            Margin="4,0"
                            ValueChanged="EraserSizeSlider_ValueChanged"/>
                </StackPanel>
                
                <!-- 영역 선택 도구 옵션 패널 -->
                <StackPanel x:Name="SelectOptionsPanel" Orientation="Horizontal" Visibility="Collapsed">
                    <Button x:Name="MosaicSelectionButton"
                            Style="{StaticResource ToolButton}"
                            ToolTip="선택 영역 모자이크"
                            Click="MosaicSelectionButton_Click"
                            Width="80"
                            Height="36"
                            Padding="8,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xF0E2;" FontFamily="Segoe Fluent Icons" FontSize="14" Foreground="#E0E0E0" Margin="0,0,4,0"/>
                            <TextBlock x:Name="MosaicText" Text="모자이크" Foreground="#E0E0E0" VerticalAlignment="Center" FontSize="12"/>
                        </StackPanel>
                    </Button>
                    
                    <Button x:Name="FillSelectionButton"
                            Style="{StaticResource ToolButton}"
                            ToolTip="선택 영역 단색 채우기 (색상 선택)"
                            Click="FillSelectionButton_Click"
                            Width="68"
                            Height="36"
                            Padding="8,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE771;" FontFamily="Segoe Fluent Icons" FontSize="14" Foreground="#E0E0E0" Margin="0,0,4,0"/>
                            <TextBlock x:Name="FillText" Text="채우기" Foreground="#E0E0E0" VerticalAlignment="Center" FontSize="12"/>
                        </StackPanel>
                    </Button>
                    
                    <Button x:Name="EraseSelectionButton"
                            Style="{StaticResource ToolButton}"
                            ToolTip="선택 영역 없애기 (투명)"
                            Click="EraseSelectionButton_Click"
                            Width="68"
                            Height="36"
                            Padding="8,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE711;" FontFamily="Segoe Fluent Icons" FontSize="14" Foreground="#E0E0E0" Margin="0,0,4,0"/>
                            <TextBlock x:Name="EraseText" Text="없애기" Foreground="#E0E0E0" VerticalAlignment="Center" FontSize="12"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
                
                <Rectangle Width="1" Fill="#3F3F46" Margin="8,4"/>
                
                <Button x:Name="UndoButton" 
                        Style="{StaticResource ToolButton}" 
                        ToolTip="실행취소 (Ctrl+Z)"
                        Click="UndoButton_Click">
                    <TextBlock Text="&#xE7A7;" FontFamily="Segoe Fluent Icons" FontSize="14" Foreground="#E0E0E0"/>
                </Button>
                
                <Button x:Name="ClearButton" 
                        Style="{StaticResource ToolButton}" 
                        ToolTip="그린 내용 모두 지우기"
                        Click="ClearButton_Click">
                    <TextBlock Text="&#xE74D;" FontFamily="Segoe Fluent Icons" FontSize="14" Foreground="#E0E0E0"/>
                </Button>
                
                <Rectangle Width="1" Fill="#3F3F46" Margin="8,4"/>
                
                <Button x:Name="FitToggleButton"
                        Style="{StaticResource ToolButton}"
                        ToolTip="창에 맞추기 / 원본 크기"
                        Click="FitToggleButton_Click"
                        Width="76"
                        Padding="8,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock x:Name="FitToggleIcon" Text="&#xE9A6;" FontFamily="Segoe Fluent Icons" FontSize="14" Foreground="#E0E0E0" Margin="0,0,4,0"/>
                        <TextBlock x:Name="FitToggleText" Text="맞추기" Foreground="#E0E0E0" VerticalAlignment="Center" FontSize="12"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Border>
        
        <!-- 텍스트 편집 영역 -->
        <TextBox x:Name="ContentTextBox"
                 Grid.Row="3"
                 AcceptsReturn="True"
                 AcceptsTab="True"
                 TextWrapping="Wrap"
                 VerticalScrollBarVisibility="Auto"
                 HorizontalScrollBarVisibility="Auto"
                 Background="#2D2D30"
                 Foreground="#E0E0E0"
                 BorderBrush="#3F3F46"
                 BorderThickness="1"
                 Padding="12"
                 FontFamily="Consolas"
                 FontSize="14"
                 CaretBrush="White"
                 SelectionBrush="#0078D4">
            <TextBox.Resources>
                <Style TargetType="ScrollBar" BasedOn="{StaticResource DarkScrollBar}"/>
            </TextBox.Resources>
        </TextBox>
        
        <!-- 이미지 편집 영역 -->
        <Border x:Name="ImageContainer"
                Grid.Row="3"
                Background="#2D2D30"
                BorderBrush="#3F3F46"
                BorderThickness="1"
                Visibility="Collapsed">
            <ScrollViewer x:Name="ImageScrollViewer"
                          HorizontalScrollBarVisibility="Auto" 
                          VerticalScrollBarVisibility="Auto"
                          Style="{StaticResource DarkScrollViewer}">
                <Canvas x:Name="CanvasContainer" 
                        ClipToBounds="True"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Top">
                    <Image x:Name="ContentImage"
                           Stretch="None"
                           Canvas.Left="0"
                           Canvas.Top="0"/>
                    <InkCanvas x:Name="DrawingCanvas"
                               Background="Transparent"
                               EditingMode="Ink"
                               Canvas.Left="0"
                               Canvas.Top="0"/>
                    <!-- 영역 선택 사각형 -->
                    <Border x:Name="SelectionRectangle"
                            BorderBrush="#0078D4"
                            BorderThickness="1.5"
                            Background="#200078D4"
                            Visibility="Collapsed"
                            IsHitTestVisible="False">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="0" ShadowDepth="0"/>
                        </Border.Effect>
                    </Border>
                </Canvas>
            </ScrollViewer>
        </Border>
        
        <!-- 하단 영역 -->
        <Grid Grid.Row="4" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <!-- 선택 정보 (좌측) -->
            <TextBlock x:Name="SelectionInfoText"
                       Grid.Column="0"
                       Foreground="#888888"
                       FontSize="11"
                       FontFamily="Consolas"
                       VerticalAlignment="Center"
                       TextTrimming="CharacterEllipsis"
                       Margin="0,0,12,0"/>
            
            <!-- 상태 메시지 + 버튼 (우측) -->
            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        VerticalAlignment="Center">
                
                <TextBlock x:Name="StatusText"
                           Foreground="#4EC9B0"
                           FontSize="12"
                           VerticalAlignment="Center"
                           Margin="0,0,16,0"/>
                
                <Button x:Name="SaveButton"
                        Content="저장"
                        Style="{StaticResource SecondaryButton}"
                        Click="SaveButton_Click"
                        Visibility="Collapsed"
                        Margin="0,0,8,0"/>
                
                <Button x:Name="CopySelectedButton"
                        Content="선택 영역 복사"
                        Style="{StaticResource SecondaryButton}"
                        Click="CopySelectedButton_Click"
                        Margin="0,0,8,0"/>
                
                <Button x:Name="CopyAllButton"
                        Content="복사 후 닫기"
                        Style="{StaticResource ActionButton}"
                        Click="CopyAllButton_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
