<Window x:Class="AutoPad.Windows.StickyWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AutoPad"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanResizeWithGrip"
        ShowInTaskbar="True"
        Width="360"
        Height="280"
        MinWidth="200"
        MinHeight="120">

    <Border Background="#2D2D30" CornerRadius="6" BorderBrush="#3F3F46" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="10" Opacity="0.5" ShadowDepth="2"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="32"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- 타이틀 바 -->
            <Border x:Name="TitleBar" Grid.Row="0" Background="#252526" CornerRadius="6,6,0,0"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               x:Name="TitleText"
                               Text="AutoPad"
                               Foreground="#999999"
                               FontSize="11"
                               VerticalAlignment="Center"
                               Margin="10,0,0,0"
                               TextTrimming="CharacterEllipsis"/>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,4,0">
                        <!-- 타이틀 바 색상 변경 -->
                        <Button x:Name="ColorButton"
                                ToolTip="Color"
                                Click="ColorButton_Click"
                                Width="28" Height="24">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="Bd" Background="Transparent" CornerRadius="3">
                                        <Border x:Name="ColorSwatch"
                                                Width="14" Height="14"
                                                CornerRadius="2"
                                                Background="#252526"
                                                BorderBrush="#555555"
                                                BorderThickness="1"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#3E3E42"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <!-- 이미지용: 창 맞추기 토글 -->
                        <Button x:Name="FitToggleButton"
                                ToolTip="Fit"
                                Click="FitToggleButton_Click"
                                Visibility="Collapsed"
                                Width="28" Height="24">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="Bd" Background="Transparent" CornerRadius="3">
                                        <TextBlock x:Name="FitIconText"
                                                   Text="&#xE9A6;"
                                                   FontFamily="Segoe Fluent Icons"
                                                   FontSize="12"
                                                   Foreground="#AAAAAA"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#3E3E42"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <!-- Always on top 토글 -->
                        <Button x:Name="TopMostButton"
                                Click="TopMostButton_Click"
                                Width="28" Height="24">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="Bd" Background="Transparent" CornerRadius="3">
                                        <TextBlock x:Name="PinIconText"
                                                   Text="&#xE718;"
                                                   FontFamily="Segoe Fluent Icons"
                                                   FontSize="12"
                                                   Foreground="#0078D4"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#3E3E42"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <!-- 편집 모드로 전환 -->
                        <Button x:Name="EditButton"
                                Click="EditButton_Click"
                                Width="28" Height="24"
                                Margin="2,0,0,0">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="Bd" Background="Transparent" CornerRadius="3">
                                        <TextBlock Text="&#xE70F;"
                                                   FontFamily="Segoe Fluent Icons"
                                                   FontSize="12"
                                                   Foreground="#AAAAAA"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#3E3E42"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <!-- 닫기 -->
                        <Button x:Name="CloseButton"
                                Click="CloseButton_Click"
                                Width="28" Height="24"
                                Margin="2,0,0,0">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="Bd" Background="Transparent" CornerRadius="3">
                                        <TextBlock Text="&#xE8BB;"
                                                   FontFamily="Segoe Fluent Icons"
                                                   FontSize="12"
                                                   Foreground="#AAAAAA"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#C42B1C"/>
                                            <Setter TargetName="Bd" Property="TextElement.Foreground" Value="White"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- 색상 선택 팝업 -->
            <Popup x:Name="ColorPopup"
                   PlacementTarget="{Binding ElementName=ColorButton}"
                   Placement="Bottom"
                   StaysOpen="False"
                   AllowsTransparency="True">
                <Border Background="#333337"
                        CornerRadius="4"
                        Padding="6"
                        BorderBrush="#555555"
                        BorderThickness="1">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="8" Opacity="0.4" ShadowDepth="2"/>
                    </Border.Effect>
                    <WrapPanel x:Name="ColorPalettePanel" Width="148">
                        <!-- 색상은 코드비하인드에서 동적 생성 -->
                    </WrapPanel>
                </Border>
            </Popup>

            <!-- 콘텐츠 영역 -->
            <Grid Grid.Row="1">
                <!-- 텍스트 모드 -->
                <TextBox x:Name="ContentTextBox"
                         Background="Transparent"
                         Foreground="#E0E0E0"
                         BorderThickness="0"
                         IsReadOnly="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Disabled"
                         Padding="10,8"
                         FontFamily="Consolas"
                         FontSize="13"
                         CaretBrush="White"
                         SelectionBrush="#0078D4"
                         Visibility="Collapsed">
                    <TextBox.Resources>
                        <Style TargetType="ScrollBar" BasedOn="{StaticResource DarkScrollBar}"/>
                    </TextBox.Resources>
                </TextBox>

                <!-- 이미지 모드 -->
                <Border x:Name="ImageContainer" Visibility="Collapsed">
                    <ScrollViewer x:Name="ImageScrollViewer"
                                  CanContentScroll="False"
                                  HorizontalScrollBarVisibility="Disabled"
                                  VerticalScrollBarVisibility="Disabled"
                                  PreviewMouseWheel="ImageScrollViewer_PreviewMouseWheel">
                        <ScrollViewer.Resources>
                            <Style TargetType="ScrollBar" BasedOn="{StaticResource DarkScrollBar}"/>
                        </ScrollViewer.Resources>
                        <Image x:Name="ContentImage"
                               Stretch="Uniform"
                               StretchDirection="Both"/>
                    </ScrollViewer>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>
